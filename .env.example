# Copy this file to .env when you are ready to enable real online donations.
# Never commit or share the real .env file.

# Persistent runtime storage for cloud hosts.
# Example for a mounted disk/volume:
# APP_STORAGE_DIR=/var/data
# Optional overrides if you want separate folders:
# DATA_DIR=/var/data/data
# UPLOAD_DIR=/var/data/uploads

PAYMENT_PROVIDER=pesapal

# Provider credentials from the payment gateway dashboard.
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
PAYMENT_CONSUMER_KEY=
PAYMENT_CONSUMER_SECRET=
PAYMENT_WEBHOOK_SECRET=

# Settlement bank details registered with the payment gateway.
SETTLEMENT_ACCOUNT_NAME="AL-IHSAN CHARITY FOUNDATION"
SETTLEMENT_BANK_NAME=
SETTLEMENT_BANK_BRANCH=
SETTLEMENT_ACCOUNT_NUMBER=
SETTLEMENT_SWIFT_BIC=
SETTLEMENT_CURRENCY=UGX

# Public website URL after deployment. Webhooks need HTTPS.
PUBLIC_SITE_URL=https://your-domain.org

# MTN MoMo Collections.
# Use this for "client confirms on phone" donations.
MTN_MOMO_ENABLED=false
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_CURRENCY=EUR
MTN_MOMO_MERCHANT_PHONE=256780937446

# After subscribing to Collections in the MTN Developer portal, the protected
# master page can save these values for you and can provision sandbox API keys.

SETTLEMENT_ACCOUNT_NAME=AL-IHSAN CHARITY FOUNDATION
SETTLEMENT_BANK_NAME=Absa Bank Uganda
SETTLEMENT_BANK_BRANCH=
SETTLEMENT_ACCOUNT_NUMBER=
SETTLEMENT_SWIFT_BIC=
SETTLEMENT_CURRENCY=UGX
SETTLEMENT_REFERENCE_PREFIX=AICF-DONATION
SETTLEMENT_INSTRUCTIONS=Use your name and donation cause as the transfer reference, then send proof for reconciliation.

ADMIN_EMAIL=jumamuyita0@gmail.com
EMAIL_PROVIDER=local-outbox
EMAIL_FROM=Al-Ihsan Charity Foundation <updates@alihsancharity.org>
RESEND_API_KEY=
BREVO_API_KEY=

AIRTEL_ENABLED=false
AIRTEL_PROVIDER=Manual Airtel Money
AIRTEL_MERCHANT_PHONE=
AIRTEL_PAYMENT_LINK=
AIRTEL_INSTRUCTIONS=Use Airtel Money and send proof for reconciliation.

PAYMENT_PROVIDER=not configured
PAYMENT_CHECKOUT_URL=
PAYMENT_PUBLIC_KEY=
PAYMENT_SECRET_KEY=
